# config/urls/__init__.py
from django.urls import path, include
from .public_urls import urlpatterns as public_urls
from .api_urls import urlpatterns as api_urls
from .auth_urls import urlpatterns as auth_urls
from .admin_urls import urlpatterns as admin_urls
from .docs_urls import urlpatterns as docs_urls
from .utility_urls import urlpatterns as utility_urls

# Combine all URL patterns
urlpatterns = []

# Add public URLs
urlpatterns += public_urls

# Add API URLs
urlpatterns += [
    # Include all API routes
    path('api/', include([
        # Authentication
        path('auth/', include(auth_urls)),
        # API v1 endpoints
        path('', include(api_urls)),
        # Documentation
        path('docs/', include(docs_urls)),
        # Utility endpoints
        path('utils/', include(utility_urls)),
        # Admin dashboard
        path('dashboard/', include('admin_dashboard.urls')),
    ])),
]